# ===================================================================
# ARCHIVO .GITIGNORE GLOBAL (RAÍZ DEL PROYECTO)
# Sistema de Gestión Archivística - Municipalidad JLO
# ===================================================================

# 📦 Dependencias y entornos de compilación
**/node_modules/
**/dist/
**/vendor/
**/.env
**/storage/*.key

# 📁 Temporales de frameworks e IDEs
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# 🚀 Caché de Laravel
/backend-archivo/bootstrap/cache/*

# Conservar archivos que mantienen la carpeta en Git
!/backend-archivo/bootstrap/cache/.gitignore
!/backend-archivo/bootstrap/cache/.gitkeep

# 📥 Datos temporales de caché
/backend-archivo/storage/framework/cache/data/*
!/backend-archivo/storage/framework/cache/data/.gitignore

# 📥 Sesiones temporales
/backend-archivo/storage/framework/sessions/*
!/backend-archivo/storage/framework/sessions/.gitignore

# 📥 Vistas compiladas
/backend-archivo/storage/framework/views/*
!/backend-archivo/storage/framework/views/.gitignore

# 📥 Archivos temporales de testing
/backend-archivo/storage/framework/testing/*
!/backend-archivo/storage/framework/testing/.gitignore

# 📄 Logs de Laravel
/backend-archivo/storage/logs/*
!/backend-archivo/storage/logs/.gitignore

# Archivos reales cargados por los operadores
# /backend-archivo/storage/app/public/*